generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  manager
  sales
  installer
  viewer
}

enum ProductStatus {
  draft
  published
  archived
}

enum OrderStatus {
  pending
  awaiting_payment
  paid
  payment_failed
  confirmed
  preparing
  delivery_scheduled
  installation_scheduled
  installed
  completed
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  cancelled
  refunded
  unknown
}

enum LeadStatus {
  new
  contacted
  quoted
  follow_up
  won
  lost
  spam
}

enum InstallationStatus {
  requested
  scheduled
  completed
  cancelled
}

enum ContentStatus {
  draft
  published
  archived
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String?
  role          Role       @default(viewer)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  assignedLeads Lead[]     @relation("AssignedLeads")
  leadNotes     LeadNote[]
}

model Brand {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  logoUrl       String?
  description   String?
  warrantyNotes String?
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  imageUrl       String?
  parentId       String?
  seoTitle       String?
  seoDescription String?
  parent         Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryChildren")
  products       Product[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Product {
  id                    String         @id @default(cuid())
  brandId               String
  categoryId            String
  name                  String
  slug                  String         @unique
  model                 String
  sku                   String         @unique
  shortDescription      String
  description           String
  price                 Decimal        @db.Decimal(10, 2)
  oldPrice              Decimal?       @db.Decimal(10, 2)
  costPrice             Decimal?       @db.Decimal(10, 2)
  currency              String         @default("GEL")
  stock                 Int            @default(0)
  status                ProductStatus  @default(draft)
  isFeatured            Boolean        @default(false)
  isBestSeller          Boolean        @default(false)
  warrantyMonths        Int            @default(24)
  installationAvailable Boolean        @default(true)
  recommendedAreaMin    Int?
  recommendedAreaMax    Int?
  btu                   Int?
  kw                    Decimal?       @db.Decimal(6, 2)
  energyClass           String?
  inverter              Boolean?
  mainImageUrl          String?
  sourceProvider        String?
  sourceUrl             String?
  sourcePriceStatus     String?
  sourceLastSyncedAt    DateTime?
  sourceRawPayload      Json?
  seoTitle              String?
  seoDescription        String?
  brand                 Brand          @relation(fields: [brandId], references: [id])
  category              Category       @relation(fields: [categoryId], references: [id])
  images                ProductImage[]
  specs                 ProductSpec[]
  orderItems            OrderItem[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([status, isBestSeller])
  @@index([categoryId, brandId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  key       String
  value     String
  group     String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                String             @id @default(cuid())
  orderNumber       String             @unique
  customerName      String
  phone             String
  email             String?
  city              String
  address           String
  district          String?
  status            OrderStatus        @default(pending)
  paymentStatus     PaymentStatus      @default(pending)
  paymentMethod     String
  subtotal          Decimal            @db.Decimal(10, 2)
  installationTotal Decimal            @default(0) @db.Decimal(10, 2)
  deliveryTotal     Decimal            @default(0) @db.Decimal(10, 2)
  discountTotal     Decimal            @default(0) @db.Decimal(10, 2)
  total             Decimal            @db.Decimal(10, 2)
  notes             String?
  items             OrderItem[]
  payments          Payment[]
  installations     InstallationTask[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model OrderItem {
  id                    String  @id @default(cuid())
  orderId               String
  productId             String?
  nameSnapshot          String
  skuSnapshot           String
  quantity              Int
  unitPrice             Decimal @db.Decimal(10, 2)
  totalPrice            Decimal @db.Decimal(10, 2)
  installationIncluded  Boolean @default(false)
  order                 Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(pending)
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("GEL")
  rawPayload        Json?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Lead {
  id                 String             @id @default(cuid())
  name               String
  phone              String
  email              String?
  source             String
  status             LeadStatus         @default(new)
  productInterest    String?
  roomSize           String?
  budget             String?
  urgency            String?
  installationNeeded Boolean?
  message            String?
  assignedToId       String?
  nextFollowUpAt     DateTime?
  assignedTo         User?              @relation("AssignedLeads", fields: [assignedToId], references: [id])
  notes              LeadNote[]
  installations      InstallationTask[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  note      String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model InstallationTask {
  id             String             @id @default(cuid())
  orderId        String?
  leadId         String?
  customerName   String
  phone          String
  address        String
  scheduledAt    DateTime?
  assignedTeam   String?
  status         InstallationStatus @default(requested)
  notes          String?
  extraCostNotes String?
  order          Order?             @relation(fields: [orderId], references: [id])
  lead           Lead?              @relation(fields: [leadId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  body           String
  coverImageUrl  String?
  status         ContentStatus @default(draft)
  seoTitle       String?
  seoDescription String?
  category       String?
  author         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  publishedAt    DateTime?
}

model FAQ {
  id          String  @id @default(cuid())
  question    String
  answer      String
  category    String?
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}

model Setting {
  key   String @id
  value Json
}

model EventLog {
  id         String   @id @default(cuid())
  type       String
  entityType String?
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())
}
